{
  "manifest_version": 2,
  "name": "Degrade",
  "author": "frutadoconde",
  "version": "1.0",
  "description": "Basic reading accessibility toggle",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg",
    "default_title": "Degrade"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "degrade@frutadoconde.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "<all_urls>",
    "tabs",
    "activeTab",
    "storage"
  ],

  "content_scripts": [
    {
      "matches":  ["https://*/*"],
      "js": ["jquery-4.0.0.slim.min.js", "content.js"]
    }
  ]

}
